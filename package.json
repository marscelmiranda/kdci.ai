{
  "name": "kdci-v4.2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "fuser -k 5000/tcp 2>/dev/null; fuser -k 5173/tcp 2>/dev/null; concurrently \"npx tsx watch server.ts\" \"vite\"",
    "build:midgard": "vite build --config midgard/vite.config.ts",
    "build": "vite build && vite build --config midgard/vite.config.ts && node scripts/prerender.mjs",
    "start": "NODE_ENV=production npx tsx server.ts",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "reactSnap": {
    "source": "dist",
    "minifyHtml": false,
    "crawl": false,
    "inlineCss": false,
    "saveAs": "html",
    "skipThirdPartyRequests": true,
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "include": [
      "/",
      "/who-we-are/",
      "/contact-us/",
      "/careers/",
      "/solutions/",
      "/solutions/ai-agent-operations/",
      "/solutions/ai-consulting-and-strategy/",
      "/solutions/ai-customer-service-agents/",
      "/solutions/ai-graphic-design/",
      "/solutions/ai-lead-generation/",
      "/solutions/ai-staffing-solutions/",
      "/blogs/",
      "/case-studies/",
      "/guides/",
      "/webinars/",
      "/ebooks/",
      "/faqs/",
      "/glossary/",
      "/privacy-policy/",
      "/terms-and-conditions/"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "latest",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
